### Test invalid offer creation (missing required fields)
# @name createInvalidOffer
POST {{SkillSwap.Api_HostAddress}}/offers
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
  "title": "",
  "description": "",
  "price": -10
}

> {%
client.test("Invalid offer creation should fail", function() {
    client.assert(response.status === 400, "Expected status 400 (Bad Request)");
});
%}

###

### Test invalid login credentials
# @name invalidLogin
POST {{SkillSwap.Api_HostAddress}}/auth/login
Content-Type: application/json

{
  "email": "nonexistent@test.com",
  "password": "wrongpassword"
}

> {%
client.test("Invalid login should fail", function() {
    client.assert(response.status === 400 || response.status === 401, "Expected status 400 or 401");
});
%}

###

### Test malformed JSON request
# @name malformedRequest
POST {{SkillSwap.Api_HostAddress}}/auth/login
Content-Type: application/json

{
  "email": "test@test.com"
  // Missing comma and password field - malformed JSON
}

> {%
client.test("Malformed request should fail", function() {
    client.assert(response.status === 400, "Expected status 400 (Bad Request)");
});
%}

