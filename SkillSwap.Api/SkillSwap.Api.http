# =============================================================================
# USER PROFILE ENDPOINTS
# =============================================================================

### Get user profile (requires authentication)
# @name getUserProfile
GET {{SkillSwap.Api_HostAddress}}/user/profile
Authorization: Bearer {{userToken}}
Accept: application/json

> {%
client.test("Get user profile successful", function() {
    client.assert(response.status === 200, "Expected status 200");
    client.assert(response.body.hasOwnProperty("id"), "Response should contain user ID");
    client.assert(response.body.hasOwnProperty("email"), "Response should contain email");
    client.assert(response.body.hasOwnProperty("displayName"), "Response should contain display name");
    client.assert(response.body.hasOwnProperty("roles"), "Response should contain roles");
    // Store the user ID for later use
    client.global.set("userId", response.body.id);
});
%}

###

### Update user profile (requires authentication)
# @name updateUserProfile
PUT {{SkillSwap.Api_HostAddress}}/user/profile
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
  "displayName": "{{testUserDisplayName}} - Updated",
  "bio": "Professional software developer with 5+ years of experience",
  "skills": "JavaScript, React, Node.js, Python, C#",
  "location": "Remote"
}

> {%
client.test("Update user profile successful", function() {
    client.assert(response.status === 200, "Expected status 200");
    client.assert(response.body.hasOwnProperty("id"), "Response should contain user ID");
    client.assert(response.body.hasOwnProperty("displayName"), "Response should contain updated display name");
});
%}

###

### Upload profile picture (requires authentication)
# @name uploadProfilePicture
POST {{SkillSwap.Api_HostAddress}}/user/profile/upload-picture
Authorization: Bearer {{userToken}}
Content-Type: multipart/form-data; boundary=----WebKitFormBoundary7MA4YWxkTrZu0gW

------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="file"; filename="profile.jpg"
Content-Type: image/jpeg

(binary data would go here)
------WebKitFormBoundary7MA4YWxkTrZu0gW--

> {%
client.test("Upload profile picture", function() {
    // This test may fail without actual file data, but shows the endpoint structure
    client.assert(response.status === 200 || response.status === 400, "Expected status 200 or 400");
});
%}

###

### Get admin profile (requires authentication)
# @name getAdminProfile  
GET {{SkillSwap.Api_HostAddress}}/user/profile
Authorization: Bearer {{adminToken}}
Accept: application/json

> {%
client.test("Get admin profile successful", function() {
    client.assert(response.status === 200, "Expected status 200");
    client.assert(response.body.hasOwnProperty("id"), "Response should contain user ID");
    client.assert(response.body.hasOwnProperty("email"), "Response should contain email");
    client.assert(response.body.hasOwnProperty("displayName"), "Response should contain display name");
    client.assert(response.body.hasOwnProperty("roles"), "Response should contain roles");
    client.assert(response.body.roles.includes("Admin"), "User should have Admin role");
    // Store the admin ID for later use
    client.global.set("adminId", response.body.id);
});
%}

