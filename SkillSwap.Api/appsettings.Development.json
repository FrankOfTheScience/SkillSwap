{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "USE_ENV_VARIABLE_OR_USER_SECRETS"
  },
  "Jwt": {
    "Key": "USE_ENV_VARIABLE_OR_USER_SECRETS",
    "Issuer": "SkillSwap",
    "Audience": "SkillSwapUsers",
    "ExpiryInMinutes": 60
  },
  "AllowedOrigins": [
    "http://localhost:3000",
    "http://localhost:3001",
    "http://localhost:3002"
  ],
  "Stripe": {
    "PublishableKey": "USE_ENV_VARIABLE_OR_USER_SECRETS",
    "SecretKey": "USE_ENV_VARIABLE_OR_USER_SECRETS",
    "WebhookSecret": "USE_ENV_VARIABLE_OR_USER_SECRETS",
    "Commission": {
      "Rate": 0.10,
      "MinimumAmount": 50
    },
    "CheckoutUrls": {
      "SuccessUrl": "http://localhost:3002/booking/success?session_id={CHECKOUT_SESSION_ID}",
      "CancelUrl": "http://localhost:3002/booking/cancel"
    }
  }
}
