{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Stripe": {
    "PublishableKey": "pk_test_STRIPE_PUBLISHABLE_KEY",
    "SecretKey": "sk_test_STRIPE_SECRET_KEY",
    "WebhookSecret": "whsec_STRIPE_WEBHOOK_SECRET",
    "Commission": {
      "Rate": 0.10,
      "MinimumAmount": 50
    },
    "CheckoutUrls": {
      "SuccessUrl": "http://localhost:3000/booking/success?session_id={CHECKOUT_SESSION_ID}",
      "CancelUrl": "http://localhost:3000/booking/cancel"
    }
  }
}
