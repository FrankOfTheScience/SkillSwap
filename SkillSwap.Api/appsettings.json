{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "USE_ENV_VARIABLE_OR_USER_SECRETS"
  },
  "Jwt": {
    "Key": "USE_ENV_VARIABLE_OR_USER_SECRETS",
    "Issuer": "SkillSwap",
    "Audience": "SkillSwapUsers",
    "ExpiryInMinutes": 60
  },
  "AllowedOrigins": [
    "http://localhost:3000",
    "http://localhost:3001"
  ],
  "Stripe": {
    "PublishableKey": "USE_ENV_VARIABLE_OR_USER_SECRETS",
    "SecretKey": "USE_ENV_VARIABLE_OR_USER_SECRETS",
    "WebhookSecret": "USE_ENV_VARIABLE_OR_USER_SECRETS",
    "Commission": {
      "Rate": 0.10,
      "MinimumAmount": 50
    },
    "CheckoutUrls": {
      "SuccessUrl": "http://localhost:3000/api/bookings/success?session_id={CHECKOUT_SESSION_ID}",
      "CancelUrl": "http://localhost:3000/booking/cancel"
    }
  },
  "Resilience": {
    "Retry": {
      "MaxAttempts": 3,
      "Delay": "00:00:01",
      "MaxDelay": "00:00:30",
      "UseJitter": true
    },
    "CircuitBreaker": {
      "HandledEventsAllowedBeforeBreaking": 5,
      "DurationOfBreak": "00:00:30",
      "MinimumThroughput": 10,
      "FailureThreshold": 0.5,
      "SamplingDuration": "00:01:00"
    },
    "Timeout": {
      "DefaultTimeout": "00:00:30",
      "DatabaseTimeout": "00:01:00",
      "HttpTimeout": "00:00:30",
      "ExternalApiTimeout": "00:00:45"
    },
    "Database": {
      "EnableRetry": true,
      "MaxRetryAttempts": 3,
      "MaxRetryDelay": "00:00:30",
      "EnableCircuitBreaker": true
    },
    "Http": {
      "EnableRetry": true,
      "EnableCircuitBreaker": true,
      "EnableTimeout": true,
      "Clients": {
        "Stripe": {
          "MaxRetryAttempts": 5,
          "Timeout": "00:00:45",
          "EnableCircuitBreaker": true,
          "CircuitBreakerFailureThreshold": 5,
          "CircuitBreakerDuration": "00:01:00"
        },
        "ExternalApi": {
          "MaxRetryAttempts": 3,
          "Timeout": "00:00:30",
          "EnableCircuitBreaker": true,
          "CircuitBreakerFailureThreshold": 3,
          "CircuitBreakerDuration": "00:00:30"
        }
      }
    }
  }
}
