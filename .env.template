# Environment Variables for SkillSwap Development

# Copy this file to .env.local and fill in your actual values
# Never commit the .env.local file to version control

# Database Configuration
DB_CONNECTION_STRING="Host=localhost;Port=5432;Database=skillswap;Username=postgres;Password=YOUR_DB_PASSWORD"

# JWT Configuration
JWT_SECRET_KEY="YOUR_LONG_SECURE_JWT_SECRET_KEY_HERE"
JWT_ISSUER="SkillSwap"
JWT_AUDIENCE="SkillSwapUsers"
JWT_EXPIRY_MINUTES=60

# Stripe Configuration
STRIPE_PUBLISHABLE_KEY="pk_test_YOUR_STRIPE_PUBLISHABLE_KEY"
STRIPE_SECRET_KEY="sk_test_YOUR_STRIPE_SECRET_KEY"
STRIPE_WEBHOOK_SECRET="whsec_YOUR_STRIPE_WEBHOOK_SECRET"

# Frontend URLs (for CORS)
CORS_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:3002"

# Stripe Configuration
STRIPE_COMMISSION_RATE=0.10
STRIPE_SUCCESS_URL="http://localhost:3002/booking/success?session_id={CHECKOUT_SESSION_ID}"
STRIPE_CANCEL_URL="http://localhost:3002/booking/cancel"